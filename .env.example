# ============================================================
# BranchTree — Production Deployment Configuration
# ============================================================
#
# SETUP:
# 1. Copy this file to .env:  cp .env.example .env
# 2. Fill in the required values below.
# 3. Run:  docker compose up -d
# 4. Read the setup token:  docker compose exec branchtree cat /app/data/.setup-token
# 5. Open your domain in a browser and complete first-run setup.
#
# ============================================================

# ─── Domain ───
# Your domain name. Caddy will auto-provision a Let's Encrypt certificate.
# Use "localhost" for local/testing (Caddy will use a self-signed cert).
DOMAIN=localhost

# ─── Encryption Key (REQUIRED) ───
# Used to encrypt secrets at rest in the database. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# or:
#   openssl rand -hex 32
#
# IMPORTANT: Back this key up. If you lose it, encrypted settings become unrecoverable.
SETTINGS_ENCRYPTION_KEY=
