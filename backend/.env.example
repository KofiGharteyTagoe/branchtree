# ============================================================
# BranchTree — Backend Configuration
# ============================================================
#
# SETUP INSTRUCTIONS:
# 1. Copy this file to .env in the same directory:
#      cp .env.example .env
# 2. Adjust any values below if needed (defaults work out of the box).
# 3. Never commit the .env file.
#
# NOTE: All secrets (JWT, encryption key, OAuth credentials) are
#       configured through the admin UI and stored in the database.
#       They are NOT set via environment variables.
#
# ============================================================

# ─── Server Settings ───
PORT=3001

# ─── Data Storage ───
# Where Git bare clones and the SQLite database are stored.
# Relative paths are resolved from the backend/ directory.
DATA_DIR=./data
DB_PATH=./data/branchtree.sqlite

# ─── Logging ───
# Log level: trace, debug, info, warn, error, fatal
LOG_LEVEL=info
