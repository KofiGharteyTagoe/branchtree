# ============================================================
# Mendix Branch Visualizer — Backend Configuration
# ============================================================
#
# SETUP INSTRUCTIONS:
# 1. Copy this file to .env in the same directory:
#      cp .env.example .env
# 2. Adjust any values below if needed (defaults work out of the box).
# 3. Never commit the .env file.
#
# NOTE: Your Mendix PAT is configured per-app through the UI,
#       not in this file. See docs/SETUP.md for details.
#
# ============================================================

# ─── Server Settings ───
PORT=3001
CORS_ORIGIN=http://localhost:5173

# ─── Data Storage ───
# Where Git bare clones and the SQLite database are stored.
# Relative paths are resolved from the backend/ directory.
DATA_DIR=./data
DB_PATH=./data/branchtree.sqlite

# ─── Security & Authentication ───
# REQUIRED: Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=
ENCRYPTION_KEY=

# OAuth callback base URL (backend URL)
OAUTH_CALLBACK_URL=http://localhost:3001
# Frontend URL (for redirects after OAuth)
FRONTEND_URL=http://localhost:5173

# ─── OAuth Providers (configure at least one) ───
# Google OAuth: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Microsoft/Entra ID: https://portal.azure.com/#blade/Microsoft_AAD_RegisteredApps
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=

# ─── Sync Settings ───
# How often to auto-sync data from Mendix (in minutes)
SYNC_INTERVAL_MINUTES=15

# Branches with no commits for this many days are flagged as stale
STALE_BRANCH_DAYS=30

# Branches this many commits behind main trigger a divergence warning
DIVERGENCE_THRESHOLD=20
